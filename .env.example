# ─────────────────────────────────────────────────────────────────────────────
# TaskCo environment variables
# Copy this file to .env.local and fill in the values. .env.local is gitignored.
# ─────────────────────────────────────────────────────────────────────────────

# ── Public (safe to expose to the browser) ──────────────────────────────────
# These are sent to the client. RLS — not secrecy — is what protects your data,
# so the anon key is intentionally public.

# Your Supabase project URL, e.g. https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anonymous (publishable) key. Public by design.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Base URL of this app, used to build auth redirect links.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── SERVER-ONLY — NEVER prefix with NEXT_PUBLIC_, never import in client code ──
# These bypass RLS / send email. Leaking them compromises the whole project.

# Supabase service-role key. Used ONLY by lib/supabase/admin.ts and Edge
# Functions. Bypasses Row Level Security. SERVER-ONLY.
SUPABASE_SERVICE_ROLE_KEY=

# Resend API key for transactional email (notification sender). SERVER-ONLY.
RESEND_API_KEY=
